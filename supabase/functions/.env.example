# Copy to .env for local dev; set in production with `supabase secrets set --env-file`.

# 32-byte base64 key for AES-256-GCM token encryption:
#   python3 -c "import base64,os; print(base64.b64encode(os.urandom(32)).decode())"
TOKEN_ENC_KEY=

# Shared secret between pg_cron and the sync/run route
SYNC_SECRET=

# Where the web app lives (oauth callback redirects here)
APP_URL=http://localhost:3000

WHOOP_CLIENT_ID=
WHOOP_CLIENT_SECRET=

STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_VERIFY_TOKEN=

EIGHTSLEEP_CLIENT_ID=
EIGHTSLEEP_CLIENT_SECRET=
